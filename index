<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Laurel — 프리미엄 케어 메일 생성기</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap');

:root {
  --bg: #F4F1EC;
  --card: #FFFFFF;
  --dark: #1C1917;
  --border: #E5DDD5;
  --green: #4A7C59;
  --green-bg: #EBF4EE;
  --gold: #C9A84C;
  --gold-bg: #FEF9E4;
  --mid: #7A726A;
  --light: #FAF8F5;
  --premium: #7A5B9E;
  --premium-bg: #F0EAF8;
  --red: #B94040;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Noto Sans KR', sans-serif;
  background: var(--bg);
  color: var(--dark);
  min-height: 100vh;
}

/* Header */
.header {
  background: var(--dark);
  padding: 24px 24px 20px;
  text-align: center;
}
.header-sub { font-size: 10px; letter-spacing: 0.25em; color: #9A9088; margin-bottom: 6px; }
.header-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  color: white;
  font-style: italic;
}
.header-desc { font-size: 12px; color: #9A9088; margin-top: 6px; }

/* Steps indicator */
.steps {
  display: flex;
  background: var(--dark);
  padding: 0 24px 16px;
  gap: 4px;
}
.step-dot {
  flex: 1;
  height: 3px;
  background: #333;
  border-radius: 2px;
  transition: background 0.3s;
}
.step-dot.active { background: var(--gold); }

/* Content */
.content { max-width: 600px; margin: 0 auto; padding: 20px 16px 100px; }

/* Section */
.section {
  background: var(--card);
  border-radius: 14px;
  border: 1px solid var(--border);
  margin-bottom: 14px;
  overflow: hidden;
}
.section-hdr {
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid var(--border);
  background: var(--light);
}
.section-num {
  width: 24px; height: 24px;
  background: var(--dark);
  color: white;
  border-radius: 50%;
  font-size: 11px;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.section-title { font-size: 14px; font-weight: 700; }
.section-body { padding: 14px 16px; }

/* Form elements */
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group.full { grid-column: 1 / -1; }
label { font-size: 10px; font-weight: 700; color: var(--mid); letter-spacing: 0.06em; }
input, select {
  padding: 10px 12px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-family: inherit;
  font-size: 13px;
  background: var(--bg);
  color: var(--dark);
  outline: none;
  -webkit-appearance: none;
}
input:focus, select:focus { border-color: var(--green); background: white; }

/* Chip selector */
.chips { display: flex; flex-wrap: wrap; gap: 6px; }
.chip {
  padding: 6px 12px;
  border-radius: 20px;
  border: 1.5px solid var(--border);
  background: white;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.15s;
  font-family: inherit;
  color: var(--dark);
}
.chip:active { transform: scale(0.97); }
.chip.selected { background: var(--dark); color: white; border-color: var(--dark); }
.chip.selected.green { background: var(--green); border-color: var(--green); }
.chip.selected.gold { background: var(--gold); border-color: var(--gold); color: var(--dark); }
.chip.selected.premium { background: var(--premium); border-color: var(--premium); }

/* Generate button */
.btn-generate {
  width: 100%;
  padding: 16px;
  background: var(--dark);
  color: white;
  border: none;
  border-radius: 12px;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
  transition: opacity 0.2s;
}
.btn-generate:active { opacity: 0.85; }
.btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-generate.loading { background: var(--mid); }

/* Result */
.result-box {
  display: none;
  background: var(--card);
  border-radius: 14px;
  border: 1px solid var(--border);
  margin-top: 16px;
  overflow: hidden;
}
.result-box.visible { display: block; }

.result-hdr {
  padding: 14px 16px;
  background: var(--premium-bg);
  border-bottom: 1px solid #C8A8E8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.result-hdr-left { display: flex; align-items: center; gap: 8px; }
.result-title { font-size: 14px; font-weight: 700; color: var(--premium); }

/* Preview — KO */
.preview-ko {
  padding: 16px;
  border-bottom: 1px solid var(--border);
}
.preview-label {
  font-size: 10px; font-weight: 700; color: var(--mid);
  letter-spacing: 0.08em; margin-bottom: 10px;
  display: flex; align-items: center; gap: 6px;
}
.preview-label::after {
  content: '';
  flex: 1; height: 1px; background: var(--border);
}
.preview-text-ko {
  font-size: 13px;
  line-height: 1.8;
  color: var(--dark);
  white-space: pre-wrap;
  background: var(--light);
  border-radius: 8px;
  padding: 14px;
  max-height: 300px;
  overflow-y: auto;
}

/* Preview — EN */
.preview-en { padding: 16px; }
.preview-text-en {
  font-size: 13px;
  line-height: 1.8;
  color: var(--dark);
  white-space: pre-wrap;
  background: var(--light);
  border-radius: 8px;
  padding: 14px;
  max-height: 400px;
  overflow-y: auto;
}

/* Action buttons */
.result-actions {
  padding: 12px 16px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 8px;
}
.btn-copy {
  flex: 1;
  padding: 13px;
  background: var(--green);
  color: white;
  border: none;
  border-radius: 10px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
}
.btn-gmail {
  flex: 1;
  padding: 13px;
  background: var(--dark);
  color: white;
  border: none;
  border-radius: 10px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
}
.btn-copy:active, .btn-gmail:active { opacity: 0.85; }

/* Loading spinner */
.spinner {
  width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  display: none;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Tip note */
.tip-note {
  background: var(--gold-bg);
  border: 1px solid #E8D08A;
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 11px;
  color: #8B6914;
  margin-top: 10px;
  line-height: 1.6;
}

/* Divider label */
.divider-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--mid);
  letter-spacing: 0.06em;
  margin: 12px 0 8px;
}
</style>
</head>
<body>

<div class="header">
  <div class="header-sub">LAUREL STUDIO · PREMIUM CARE</div>
  <div class="header-title">Expert Tip Generator</div>
  <div class="header-desc">고객 정보 입력 → AI 전문가팁 생성 → 이메일 발송</div>
</div>

<div class="steps">
  <div class="step-dot active" id="s1"></div>
  <div class="step-dot" id="s2"></div>
  <div class="step-dot" id="s3"></div>
</div>

<div class="content">

  <!-- 1. 고객 기본 정보 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">1</div>
      <div class="section-title">고객 기본 정보</div>
    </div>
    <div class="section-body">
      <div class="form-row">
        <div class="form-group">
          <label>이름 (Name)</label>
          <input type="text" id="guestName" placeholder="예: Sarah">
        </div>
        <div class="form-group">
          <label>이메일 (Email)</label>
          <input type="email" id="guestEmail" placeholder="guest@email.com">
        </div>
        <div class="form-group">
          <label>나이대</label>
          <select id="guestAge">
            <option value="">선택</option>
            <option>10대</option>
            <option>20대</option>
            <option>30대</option>
            <option>40대</option>
            <option>50대</option>
            <option>60대 이상</option>
          </select>
        </div>
        <div class="form-group">
          <label>성별</label>
          <select id="guestGender">
            <option value="">선택</option>
            <option>여성</option>
            <option>남성</option>
          </select>
        </div>
        <div class="form-group full">
          <label>국가 / 출력 언어</label>
          <select id="guestCountry">
            <option value="">선택</option>
            <option value="미국 (영어)">미국 (영어)</option>
            <option value="영국 (영어)">영국 (영어)</option>
            <option value="호주 (영어)">호주 (영어)</option>
            <option value="프랑스 (프랑스어)">프랑스 (프랑스어)</option>
            <option value="일본 (영어)">일본 (영어)</option>
            <option value="중국 (영어)">중국 (영어)</option>
            <option value="레바논 (아랍어+프랑스어)">레바논 (아랍어+프랑스어)</option>
            <option value="기타 (영어)">기타 (영어)</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. 피부 특성 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">2</div>
      <div class="section-title">피부 특성 (복수 선택 가능)</div>
    </div>
    <div class="section-body">
      <div class="chips" id="skinTypeChips">
        <button class="chip" onclick="toggleChip(this,'skinTypes')">얇은 피부</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">건조</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">지성</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">복합성</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">민감성</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">아토피</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">초예민</button>
        <button class="chip" onclick="toggleChip(this,'skinTypes')">정상</button>
      </div>
    </div>
  </div>

  <!-- 3. 주요 고민 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">3</div>
      <div class="section-title">주요 피부 고민 (복수 선택)</div>
    </div>
    <div class="section-body">
      <div class="chips" id="concernChips">
        <button class="chip" onclick="toggleChip(this,'concerns')">트러블/여드름</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">홍조</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">모공</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">색소침착/잡티</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">주름/탄력</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">다크서클</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">각질</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">편평사마귀</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">모공 속 털</button>
        <button class="chip" onclick="toggleChip(this,'concerns')">흔적/자국</button>
      </div>
    </div>
  </div>

  <!-- 4. 케어 버전 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">4</div>
      <div class="section-title">케어 버전</div>
    </div>
    <div class="section-body">
      <div class="chips">
        <button class="chip selected premium" id="careBasic" onclick="selectCare('basic')">베이직 케어</button>
        <button class="chip" id="carePremium" onclick="selectCare('premium')">프리미엄 케어</button>
      </div>
    </div>
  </div>

  <!-- 5. 추천 제품 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">5</div>
      <div class="section-title">추천 제품 (해당하는 것 선택)</div>
    </div>
    <div class="section-body">
      <div class="divider-label">기본 보습</div>
      <div class="chips" style="margin-bottom:10px;">
        <button class="chip" onclick="toggleChip(this,'products')">아토베리어 365 크림</button>
        <button class="chip" onclick="toggleChip(this,'products')">피지오겔 DMT 크림</button>
        <button class="chip" onclick="toggleChip(this,'products')">세타필 모이스춰라이징 크림</button>
        <button class="chip" onclick="toggleChip(this,'products')">MIXSOON 콩에센스</button>
        <button class="chip" onclick="toggleChip(this,'products')">아토팜 판테놀크림</button>
        <button class="chip" onclick="toggleChip(this,'products')">다이소 닥터씨피유 수분 앰플</button>
      </div>
      <div class="divider-label">선크림</div>
      <div class="chips" style="margin-bottom:10px;">
        <button class="chip" onclick="toggleChip(this,'products')">다이소 마린 수분광채 선젤 SPF50+</button>
      </div>
      <div class="divider-label">안티에이징</div>
      <div class="chips" style="margin-bottom:10px;">
        <button class="chip" onclick="toggleChip(this,'products')">본셉 레티놀 2500IU (다이소)</button>
      </div>
      <div class="divider-label">흔적/미백</div>
      <div class="chips" style="margin-bottom:10px;">
        <button class="chip" onclick="toggleChip(this,'products')">파티온 노스카나인 흔적앰플 (다이소)</button>
        <button class="chip" onclick="toggleChip(this,'products')">트리넥삼산 처방약</button>
      </div>
      <div class="divider-label">트러블 스팟</div>
      <div class="chips">
        <button class="chip" onclick="toggleChip(this,'products')">큐아크네 플러스 크림 (약국)</button>
      </div>
    </div>
  </div>

  <!-- 6. 특이사항 -->
  <div class="section">
    <div class="section-hdr">
      <div class="section-num">6</div>
      <div class="section-title">특이사항 (선택)</div>
    </div>
    <div class="section-body">
      <div class="chips" style="margin-bottom:10px;">
        <button class="chip" onclick="toggleChip(this,'special')">수염 있음</button>
        <button class="chip" onclick="toggleChip(this,'special')">임산부</button>
        <button class="chip" onclick="toggleChip(this,'special')">루푸스</button>
        <button class="chip" onclick="toggleChip(this,'special')">당뇨</button>
        <button class="chip" onclick="toggleChip(this,'special')">심혈관 질환</button>
        <button class="chip" onclick="toggleChip(this,'special')">메이크업 자주 함</button>
      </div>
      <div class="form-group" style="margin-top:10px;">
        <label>추가 메모 (직접 입력)</label>
        <input type="text" id="extraNote" placeholder="예: 레이저 시술 후 회복 중, 임신 6개월 등">
      </div>
    </div>
  </div>

  <div class="tip-note">
    💡 선택 후 <strong>"전문가팁 생성"</strong> 버튼을 누르면 AI가 위 정보를 조합해 맞춤 영문 전문가팁을 만들어줍니다. 한국어 요약도 함께 생성돼요.
  </div>

  <button class="btn-generate" id="generateBtn" onclick="generateTip()">
    <div class="spinner" id="spinner"></div>
    <span id="generateLabel">✨ 전문가팁 생성하기</span>
  </button>

  <!-- Result -->
  <div class="result-box" id="resultBox">
    <div class="result-hdr">
      <div class="result-hdr-left">
        <span style="font-size:18px;">⭐</span>
        <div class="result-title">전문가팁 생성 완료</div>
      </div>
      <span style="font-size:11px;color:var(--mid)" id="resultName"></span>
    </div>

    <div class="preview-ko">
      <div class="preview-label">한국어 요약 (내부 확인용)</div>
      <div class="preview-text-ko" id="koText">—</div>
    </div>

    <div class="preview-en">
      <div class="preview-label">영문 전문가팁 (고객 발송용)</div>
      <div class="preview-text-en" id="enText">—</div>
    </div>

    <div class="result-actions">
      <button class="btn-copy" onclick="copyEN()">📋 영문 복사</button>
      <button class="btn-gmail" onclick="openGmail()">📧 Gmail 열기</button>
    </div>
  </div>

</div>

<script>
const selections = { skinTypes: [], concerns: [], products: [], special: [] };
let careVersion = 'basic';
let generatedEN = '';
let guestEmailValue = '';
let guestNameValue = '';

function toggleChip(el, group) {
  const val = el.textContent.trim();
  const idx = selections[group].indexOf(val);
  if (idx > -1) {
    selections[group].splice(idx, 1);
    el.classList.remove('selected', 'green');
  } else {
    selections[group].push(val);
    el.classList.add('selected', 'green');
  }
  updateSteps();
}

function selectCare(type) {
  careVersion = type;
  document.getElementById('careBasic').className = 'chip' + (type === 'basic' ? ' selected premium' : '');
  document.getElementById('carePremium').className = 'chip' + (type === 'premium' ? ' selected premium' : '');
}

function updateSteps() {
  const s1 = document.getElementById('guestName').value && document.getElementById('guestEmail').value;
  const s2 = selections.skinTypes.length > 0 || selections.concerns.length > 0;
  document.getElementById('s1').classList.toggle('active', !!s1);
  document.getElementById('s2').classList.toggle('active', s2);
}

document.getElementById('guestName').addEventListener('input', updateSteps);
document.getElementById('guestEmail').addEventListener('input', updateSteps);

function buildPrompt() {
  const name = document.getElementById('guestName').value.trim();
  const age = document.getElementById('guestAge').value;
  const gender = document.getElementById('guestGender').value;
  const country = document.getElementById('guestCountry').value;
  const extra = document.getElementById('extraNote').value.trim();

  return `당신은 로렐 스튜디오의 피부 성분 전문가입니다. 아래 고객 정보를 바탕으로 개인화된 전문가 피부 팁을 영문으로 작성해주세요.

【고객 정보】
- 이름: ${name || '고객'}
- 나이대: ${age || '미입력'}
- 성별: ${gender || '미입력'}
- 국가/언어: ${country || '영어'}
- 피부 특성: ${selections.skinTypes.join(', ') || '일반'}
- 주요 고민: ${selections.concerns.join(', ') || '기본 보습'}
- 케어 버전: ${careVersion === 'premium' ? '프리미엄 케어' : '베이직 케어'}
- 추천 제품: ${selections.products.join(', ') || '아토베리어 365 크림'}
- 특이사항: ${[...selections.special, extra].filter(Boolean).join(', ') || '없음'}

【작성 원칙】
1. 고객 이름을 자주 불러주며 상냥하고 따뜻하게 작성
2. 피부 과학 근거를 쉽게 설명 (전문 용어는 간단히 풀어서)
3. 세안 루틴, 보습 루틴, 선크림, 각질 관리, 추천 제품 사용법 포함
4. 추천 제품은 구체적인 사용량(검지 1마디 등)과 순서 명시
5. 안티에이징 해당 시 레티놀 단계별 일정 포함
6. 마지막에 따뜻한 응원 메시지로 마무리
7. 영문으로 작성하되 자연스럽고 읽기 쉽게

