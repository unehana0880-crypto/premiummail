async function generateTip() {
  const name = document.getElementById('guestName').value.trim();
  const email = document.getElementById('guestEmail').value.trim();

  if (!name || !email) {
    alert('이름과 이메일을 입력해주세요!');
    return;
  }

  guestNameValue = name;
  guestEmailValue = email;

  const btn = document.getElementById('generateBtn');
  const spinner = document.getElementById('spinner');
  const label = document.getElementById('generateLabel');

  btn.disabled = true;
  btn.classList.add('loading');
  spinner.style.display = 'block';
  label.textContent = '생성 중...';

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: buildPrompt() }]
      })
    });

    const data = await response.json();
    const full = data.content[0].text;

    // Split EN and KO
    const parts = full.split('---');
    const enPart = parts[0].trim();
    const koPart = parts[1] ? parts[1].replace('[한국어 요약]', '').trim() : '요약 생성 중...';

    generatedEN = enPart;

    document.getElementById('enText').textContent = enPart;
    document.getElementById('koText').textContent = koPart;
    document.getElementById('resultName').textContent = name + ' 고객';
    document.getElementById('resultBox').classList.add('visible');
    document.getElementById('s3').classList.add('active');

    // Scroll to result
    document.getElementById('resultBox').scrollIntoView({ behavior: 'smooth', block: 'start' });

  } catch (e) {
    alert('생성 중 오류가 발생했어요. 다시 시도해주세요.\n' + e.message);
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
    spinner.style.display = 'none';
    label.textContent = '✨ 다시 생성하기';
  }
}

function copyEN() {
  if (!generatedEN) return;
  const btn = document.querySelector('.btn-copy');
  navigator.clipboard.writeText(generatedEN).then(() => {
    btn.textContent = '✅ 복사됐어요!';
    setTimeout(() => btn.textContent = '📋 영문 복사', 2000);
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = generatedEN;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = '✅ 복사됐어요!';
    setTimeout(() => btn.textContent = '📋 영문 복사', 2000);
  });
}

function openGmail() {
  if (!guestEmailValue) return;
  const subject = encodeURIComponent(`Your Personalized Skincare Guide from Laurel Studio 🌿`);
  const body = encodeURIComponent(generatedEN);
  const url = `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(guestEmailValue)}&su=${subject}&body=${body}`;
  window.open(url, '_blank');
}
